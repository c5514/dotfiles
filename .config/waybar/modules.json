{
  // Workspaces
  "hyprland/workspaces": {
    "on-scroll-up": "hyprctl dispatch workspace r-1",
    "on-scroll-down": "hyprctl dispatch workspace r+1",
    "on-click": "activate",
    "active-only": false,
    "all-outputs": true,
    "format": "{}",
    "format-icons": {
      "1": "’äī",
      "2": "’äī",
      "3": "’äī",
      "4": "’äī",
      "5": "’äī",
      "6": "’äī",
      "urgent": "’ü¬",
      "active": "’åÆ",
      "default": "’äæ"
    },
    "format-icons": {
      "urgent": "",
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
            "*": 0
    }
  },

  // Taskbar
  "wlr/taskbar": {
    "format": "{icon}",
    "icon-size": 18,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-middle": "close",
    "ignore-list": ["Alacritty", "kitty"],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    },
    "rewrite": {
      "Firefox Web Browser": "Firefox",
      "Foot Server": "Terminal"
    }
  },

  // Hyprland Window
  "hyprland/window": {
    "rewrite": {
      "(.*) - Brave": "$1",
      "(.*) - Chromium": "$1",
      "(.*) - Brave Search": "$1",
      "(.*) - Outlook": "$1",
      "(.*) Microsoft Teams": "$1"
    },
    "separate-outputs": true
  },

  // Empty
  "custom/empty": {
    "format": ""
  },
  
  // Empty
  "custom/tools": {
    "format": "’ŚĮ",
    "tooltip-format": "Tools"
  },

  // Cliphist
  "custom/cliphist": {
    "format": "’ā¬",
    "on-click": "sleep 0.1 && cliphist list | rofi -dmenu -theme ~/.config/rofi/cliphist.rasi| cliphist decode | wl-copy",
    "on-click-right": "sleep 0.1 && cliphist list | rofi -dmenu -theme ~/.config/rofi/cliphist.rasi| cliphist delete",
    "on-click-middle": "sleep 0.1 && cliphist wipe",
    "tooltip-format": "Clipboard Manager: Left(select), right(delete), center(clean)"
  },

  // Wallpaper
  "custom/wallpaper": {
    "format": "’ĆŠ",
    "on-click": "waypaper",
    "on-click-right": "waypaper --random",
    "tooltip-format": "Left: Select a wallpaper\nRight: Select a random wallpaper"
  },

  // Waybar Themes
  "custom/waybarthemes": {
    "format": "’ģü",
    "on-click": "~/dotfiles/waybar/themeswitcher.sh",
    "tooltip-format": "Select a waybar theme"
  },

  // Keybindings
  "custom/keybindings": {
    "format": "’ä£",
    "on-click": "~/dotfiles/hypr/scripts/keybindings.sh",
    "tooltip": false
  },

  // ChatGPT Launcher
  "custom/chatgpt": {
    "format": "¾░¤Ź",
    "on-click": "firefox https://poe.com/",
    "tooltip-format": "AI Support"
  },
  "custom/whatsapp": {
    "format": "’ł▓",
    "on-click": "firefox https://web.whatsapp.com",
    "tooltip-format": "WhatsApp Web"
  },
  // Calculator
  "custom/calculator": {
    "format": "’ć¼",
    "on-click": "qalculate-gtk",
    "tooltip-format": "Open calculator"
  },

  // Windows VM
  "custom/windowsvm": {
    "format": "’ģ║",
    "on-click": "~/dotfiles/scripts/launchvm.sh",
    "tooltip": false
  },

  // Rofi Application Launcher
  "custom/appmenu": {
    // START APPS LABEL
    "format": "’īō ",
    // END APPS LABEL
"on-click": "sleep 0.2; if pgrep -x rofi > /dev/null; then pkill rofi; else rofi -show drun -replace; fi",
    "tooltip-format": "Open/Close the application launcher"
  },

  // Rofi Application Launcher
  "custom/appmenuicon": {
    "format": "’īā",
    "on-click": "rofi -show drun -replace",
    "on-click-right": "~/dotfiles/hypr/scripts/keybindings.sh",
    "tooltip-format": "Left: Open the application launcher\nRight: Show all keybindings"
  },

  // Power Menu
  "custom/exit": {
    "format": "’Ćæ",
    "on-click": "wlogout",
    "tooltip-format": "Power Menu"
  },

  // Hyprshade
  "custom/hyprshade": {
    "format": "Ņō£",
    "tooltip-format": "Blue-light filter on/off",
"on-click": "sleep 0.5; if hyprshade current | grep -q 'blue-light-filter'; then hyprshade off; else hyprshade on blue-light-filter; fi",
  },

  // Hypridle inhibitor
  "custom/hypridle": {
    "format": "’ĆŻ",
    "return-type": "json",
    "escape": true,
    "exec-on-event": true,
    "interval": 60,
    "exec": "~/dotfiles/hypr/scripts/hypridle.sh status",
    "on-click": "~/dotfiles/hypr/scripts/hypridle.sh toggle",
    "on-click-right": "hyprlock"
  },

  // Keyboard State
  "keyboard-state": {
    "numlock": true,
    "capslock": true,
    "format": "{name} {icon}",
    "format-icons": {
      "locked": "’ĆŻ",
      "unlocked": "’é£"
    }
  },

  // System tray
  "tray": {
    "icon-size": 21,
    "spacing": 10
  },

  // Clock
  "clock": {
    "format": "{:%H:%M %a}",
    // "timezone": "America/New_York",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    // START CLOCK FORMAT
    "format-alt": "{:%Y-%m-%d}"
    // END CLOCK FORMAT
  },

  // System
  "custom/system": {
    "format": "Ņæ│",
    "tooltip": false
  },

  // CPU
  "cpu": {
    "format": "/ CPU: {usage}% "
  },

  // Memory
  "memory": {
    "format": "/ ’öĖ {}% "
  },
  "temperature": {
    "thermal-zone": 0,
    "critical-threshold": 80,
    "format-critical": " {temperatureC}┬░C",
    "format": "/ ’ŗŖ {temperatureC}┬░C  "
  },
  // Harddisc space used
  "disk": {
    "interval": 30,
    "format": "¾░ŗŖ  {percentage_used}% "
  },

  "hyprland/language": {
    "format": " ’ä£ {short}"
  },

  // Group Hardware
  "group/hardware": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": ["custom/system", "disk", "memory", "temperature"]
  },

  // Group Tools
  "group/tools": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": false
    },
    "modules": [
      "custom/cliphist",
      "custom/wallpaper",
      "custom/hypridle",
      "custom/hyprshade"
    ]
  },

  // Group Links
  "group/links": {
    "orientation": "horizontal",
    "modules": [
      // "custom/chatgpt",
	  "custom/whatsapp",
      "custom/empty"      
    ]
  },

  // Group Settings
  "group/settings": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 300,
      "children-class": "not-memory",
      "transition-left-to-right": true
    },
    "modules": [
      "custom/settings",
      "custom/waybarthemes"
    ]
  },

  // Network
  "network": {
    "format": "{ifname}",
    "format-wifi": "’ć½   {signalStrength}%",
    "format-ethernet": "’×¢  {ifname}",
    "format-disconnected": "Disconnected",
    "tooltip-format": "’×¢ {ifname} via {gwaddri}",
    "tooltip-format-wifi": "’ć½  {ifname} @ {essid}\nIP: {ipaddr}\nStrength: {signalStrength}%\nFreq: {frequency}MHz\nUp: {bandwidthUpBits} Down: {bandwidthDownBits}",
    "tooltip-format-ethernet": "’×¢ {ifname}\nIP: {ipaddr}\n up: {bandwidthUpBits} down: {bandwidthDownBits}",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "on-click": "kitty --class floating -e nmtui",
    "on-click-right": "nm-connection-editor"
  },

  // Battery
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "’Ś¦  {capacity}%",
    "format-plugged": "’ć”  {capacity}%",
    "format-alt": "{icon}  {time}",
    // "format-good": "", // An empty format will hide the module
    // "format-full": "",
    "format-icons": ["’ēä ", "’ēā ", "’ēé ", "’ēü ", "’ēĆ "]
  },

  // Pulseaudio
  "pulseaudio": {
    // "scroll-step": 1, // %, can be a float
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{volume}% {icon}’Ŗö {format_source}",
    "format-bluetooth-muted": "’Ü® {icon}’Ŗö {format_source}",
    "format-muted": "’Ü®  {volume}%",
    "format-source": "{volume}% ’ä░",
    "format-source-muted": "’ä▒",
    "format-icons": {
      "headphone": "’Ćź ",
      "hands-free": "’¢É ",
      "headset": "’¢É ",
      "phone": "’éĢ ",
      "portable": "’éĢ ",
      "car": "’å╣ ",
      "default": ["’Ć”", "’Ć©", "’Ć©"]
    },
    "on-click": "wpctl set-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },

  // Bluetooth
  "bluetooth": {
    "format": "’Ŗō {status}",
    "format-disabled": "¾░é▓ off",
    "format-off": "¾░é▓ off",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },

  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  // backlight:
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": [
      "ŅÄŹ",
      "ŅÅö",
      "ŅÅō",
      "ŅÅÆ",
      "ŅÅæ",
      "ŅÅÉ",
      "ŅÅÅ",
      "ŅÅÄ",
      "ŅÅŹ",
      "ŅÅī",
      "ŅÅŗ",
      "ŅÅŖ",
      "ŅÅē",
      "ŅÅł",
      "ŅÄø"
    ],
    "scroll-step": 1
  }
}
